run = "streamlit run app.py --server.port 8080 --server.address 0.0.0.0"
modules = ["nodejs-24", "python-3.11"]

[deployment]
deploymentTarget = "cloudrun"
run = ["sh", "-c", "cd scripts/src && streamlit run app.py --server.port 8080 --server.address 0.0.0.0"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run scripts/src/app.py --server.port 8501 --server.headless true --server.address 0.0.0.0 --server.enableCORS false --server.enableXsrfProtection false"
waitForPort = 8501

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["codespelunker"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8501
externalPort = 3000




